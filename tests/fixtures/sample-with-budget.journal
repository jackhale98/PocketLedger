; Sample hledger journal with budget periodic transactions
; For testing PocketHLedger's budget features

; Commodities
commodity $1,000.00

; Account declarations
account assets:checking
account assets:savings
account expenses:rent
account expenses:groceries
account expenses:dining
account expenses:transport
account expenses:utilities
account expenses:subscriptions
account income:salary
account income:freelance
account liabilities:credit-card

; Budget - monthly spending targets
~ monthly
    expenses:rent                $1,500.00
    expenses:groceries             $400.00
    expenses:dining                $200.00
    expenses:transport             $150.00
    expenses:utilities             $120.00
    expenses:subscriptions          $50.00
    income

