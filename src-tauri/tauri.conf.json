{
  "$schema": "https://raw.githubusercontent.com/nicegui/Tauri/tauri-v2/crates/tauri-config-schema/schema.json",
  "productName": "PocketLedger",
  "version": "0.1.0",
  "identifier": "com.pocketledger.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "PocketLedger",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
